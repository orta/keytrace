{
  "name": "@keytrace/claims",
  "version": "1.2.3",
  "description": "Get Keytrace identity claims, and also verify their signatures. Works in both browser and Node.js.",
  "repository": {
    "type": "git",
    "url": "https://github.com/orta/keytrace",
    "directory": "packages/claims"
  },
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "main": "./dist/verify.js",
  "types": "./dist/verify.d.ts",
  "exports": {
    ".": {
      "types": "./dist/verify.d.ts",
      "default": "./dist/verify.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
