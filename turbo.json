{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".nuxt/**", ".output/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["KEYTRACE_TAP_URL", "KEYTRACE_TAP_ADMIN_PASSWORD", "KEYTRACE_REVERSE_LOOKUP_DB"]
    },
    "test": {
      "dependsOn": ["build"],
      "env": ["KEYTRACE_REVERSE_LOOKUP_DB"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
